# OpenClaw management commands (nix-openclaw native)

# Use bash so we can source the env file (fish can't source KEY=value files)
set shell := ["bash", "-c"]

# Source secrets and set config path for CLI commands
export OPENCLAW_CONFIG_PATH := "/etc/openclaw/openclaw.json"
ocenv := "set -a; source /run/secrets/openclaw-env; set +a;"

# Default: show available commands
default:
    @just --list

# === Service Management ===

# Start OpenClaw gateway
start:
    systemctl start openclaw-gateway

# Stop OpenClaw gateway
stop:
    systemctl stop openclaw-gateway

# Restart OpenClaw gateway
restart:
    systemctl restart openclaw-gateway

# Show service status
status:
    systemctl status openclaw-gateway --no-pager

# === Logs ===

# Follow gateway logs
logs:
    journalctl -u openclaw-gateway -f

# Show last N lines of logs (default: 50)
logs-tail n="50":
    journalctl -u openclaw-gateway --no-pager -n {{n}}

# === CLI ===

# Run openclaw CLI command
cli *args:
    {{ocenv}} openclaw {{args}}

# Show OpenClaw version
version:
    {{ocenv}} openclaw --version

# Run OpenClaw doctor
doctor:
    {{ocenv}} openclaw doctor

# Run onboarding
onboard:
    {{ocenv}} openclaw onboard

# === ClawHub ===

# Search ClawHub for skills
clawhub-search query:
    {{ocenv}} openclaw skills clawhub search "{{query}}"

# Install a ClawHub skill
clawhub-install skill:
    {{ocenv}} openclaw skills clawhub install {{skill}}

# Update all ClawHub skills
clawhub-update:
    {{ocenv}} openclaw skills clawhub update --all

# List installed skills
clawhub-list:
    {{ocenv}} openclaw skills clawhub list

# Login to ClawHub
clawhub-login:
    {{ocenv}} openclaw skills clawhub login

# === Skills ===

# List installed skills
skills:
    {{ocenv}} openclaw skills list

# Search skills
skills-search query:
    {{ocenv}} openclaw skills search "{{query}}"

# Show skill details
skills-info name:
    {{ocenv}} openclaw skills info {{name}}

# Check skills status
skills-check:
    {{ocenv}} openclaw skills check

# === Channels ===

# List configured channels
channels:
    {{ocenv}} openclaw channels list

# Show channel status
channels-status:
    {{ocenv}} openclaw channels status

# Show channel logs
channels-logs:
    {{ocenv}} openclaw channels logs

# Add a channel (interactive)
channels-add channel:
    {{ocenv}} openclaw channels add --channel {{channel}}

# === Nodes ===

# List connected nodes
nodes:
    {{ocenv}} openclaw nodes status

# === Models ===

# List available models
models:
    {{ocenv}} openclaw models list

# Show model status (auth, expiry)
models-status:
    {{ocenv}} openclaw models status

# Scan for models
models-scan:
    {{ocenv}} openclaw models scan

# === Health & Status ===

# Check gateway health
health:
    {{ocenv}} openclaw health

# === Sessions ===

# List sessions
sessions:
    {{ocenv}} openclaw sessions

# === Pairing ===

# List pending pairing requests
pairing:
    {{ocenv}} openclaw pairing list

# Approve a pairing request
pairing-approve channel code:
    {{ocenv}} openclaw pairing approve {{channel}} {{code}}

# === Cron ===

# List cron jobs
cron-list:
    {{ocenv}} openclaw cron list

# Show cron job details
cron-show job:
    {{ocenv}} openclaw cron show {{job}}

# Show cron status
cron-status:
    {{ocenv}} openclaw cron status

# === Config ===

# Show current config
config:
    cat /etc/openclaw/openclaw.json | jq

# Edit config
config-edit:
    $EDITOR /etc/openclaw/openclaw.json

# Validate config
config-validate:
    {{ocenv}} openclaw config validate

# Get a config value
config-get path:
    {{ocenv}} openclaw config get {{path}}

# === Data ===

# Show state directory contents
data:
    ls -la /var/lib/openclaw/

# Show workspace contents
workspace:
    ls -la /var/lib/openclaw/workspace/

# === Browser ===

# Start browser
browser-start:
    {{ocenv}} openclaw browser start

# Stop browser
browser-stop:
    {{ocenv}} openclaw browser stop

# Show browser tabs
browser-tabs:
    {{ocenv}} openclaw browser tabs

# === Gateway ===

# Probe gateway
gateway-probe:
    {{ocenv}} openclaw gateway probe

# === Backup ===

# Create a backup of OpenClaw data
backup name="openclaw-backup":
    tar -czvf /tmp/{{name}}-$(date +%Y%m%d-%H%M%S).tar.gz -C /var/lib/openclaw .
    @echo "Backup created at /tmp/{{name}}-$(date +%Y%m%d-%H%M%S).tar.gz"

# === Maintenance ===

# Clear stale session locks
clear-locks:
    rm -f /var/lib/openclaw/agents/*/sessions/*.lock
    @echo "Session locks cleared"

# Update openclaw (nixos-rebuild)
update:
    @echo "Run 'nixos-rebuild switch --flake .' to update OpenClaw"

# Run openclaw in-app update
update-cli:
    {{ocenv}} openclaw update

# === TUI ===

# Open terminal UI
tui:
    {{ocenv}} openclaw tui

# === Agents ===

# List agents
agents:
    {{ocenv}} openclaw agents list



# === Fish shell ===

# Fix fish autocomplete error
fish:
  true