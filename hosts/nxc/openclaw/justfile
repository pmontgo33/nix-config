# OpenClaw management commands

# Default: show available commands
default:
    @just --list

# Completion helper (used by shell completion)
completion:
    @just --list --list-prefix '' --list-heading '' | awk '{print $1}'

# === Container Management ===

# Start the OpenClaw container
start:
    systemctl start podman-openclaw

# Stop the OpenClaw container
stop:
    systemctl stop podman-openclaw

# Restart the OpenClaw container
restart:
    systemctl restart podman-openclaw

# Show container status
status:
    podman ps -a --filter name=openclaw
    @echo ""
    systemctl status podman-openclaw --no-pager

# === Logs ===

# Follow container logs
logs:
    podman logs -f openclaw

# Show last N lines of logs (default: 50)
logs-tail n="50":
    podman logs --tail {{n}} openclaw

# === Shell & CLI ===

# Open a bash shell inside the container
shell:
    podman exec -it openclaw bash

# Run openclaw CLI command
cli *args:
    podman exec -it openclaw node /app/openclaw.mjs {{args}}

# Run onboarding
onboard:
    podman exec -it openclaw node /app/openclaw.mjs onboard

# Show OpenClaw version
version:
    podman exec openclaw node /app/openclaw.mjs --version

# Run OpenClaw doctor
doctor:
    podman exec -it openclaw node /app/openclaw.mjs doctor

# Fix OpenClaw config issues
doctor-fix:
    podman exec -it openclaw node /app/openclaw.mjs doctor --fix

# === ClawHub ===

# Search ClawHub for skills
clawhub-search query:
    podman exec -it openclaw npx clawhub search "{{query}}"

# Install a ClawHub skill
clawhub-install skill:
    podman exec -it openclaw npx clawhub install {{skill}}

# Update all ClawHub skills
clawhub-update:
    podman exec -it openclaw npx clawhub update --all

# List installed skills
clawhub-list:
    podman exec -it openclaw npx clawhub list

# Login to ClawHub
clawhub-login:
    podman exec -it openclaw npx clawhub login

# === Skills ===

# List installed skills
skills:
    podman exec openclaw node /app/openclaw.mjs skills list

# Search skills
skills-search query:
    podman exec openclaw node /app/openclaw.mjs skills search "{{query}}"

# Show skill details
skills-info name:
    podman exec openclaw node /app/openclaw.mjs skills info {{name}}

# Check skills status
skills-check:
    podman exec openclaw node /app/openclaw.mjs skills check

# === Channels ===

# List configured channels
channels:
    podman exec openclaw node /app/openclaw.mjs channels list

# Show channel status
channels-status:
    podman exec openclaw node /app/openclaw.mjs channels status

# Show channel logs
channels-logs:
    podman exec openclaw node /app/openclaw.mjs channels logs

# Add a channel (interactive)
channels-add channel:
    podman exec -it openclaw node /app/openclaw.mjs channels add --channel {{channel}}

# === Nodes ===

# List connected nodes
nodes:
    podman exec openclaw node /app/openclaw.mjs nodes status

# === Models ===

# List available models
models:
    podman exec openclaw node /app/openclaw.mjs models list

# Show model status (auth, expiry)
models-status:
    podman exec openclaw node /app/openclaw.mjs models status

# Scan for models
models-scan:
    podman exec -it openclaw node /app/openclaw.mjs models scan

# === Health & Status ===

# Check gateway health
health:
    podman exec openclaw node /app/openclaw.mjs health

# === Sessions ===

# List sessions
sessions:
    podman exec openclaw node /app/openclaw.mjs sessions

# === Cron ===

# List cron jobs
cron-list:
    podman exec openclaw node /app/openclaw.mjs cron list

# Show cron job details
cron-show job:
    podman exec openclaw node /app/openclaw.mjs cron show {{job}}

# Show cron status
cron-status:
    podman exec openclaw node /app/openclaw.mjs cron status

# === Config ===

# Show current config
config:
    cat /var/lib/openclaw/openclaw.json | jq

# Edit config
config-edit:
    $EDITOR /var/lib/openclaw/openclaw.json

# Validate config
config-validate:
    podman exec openclaw node /app/openclaw.mjs config validate

# Get a config value
config-get path:
    podman exec openclaw node /app/openclaw.mjs config get {{path}}

# === Data ===

# Show data directory contents
data:
    ls -la /var/lib/openclaw/

# Show workspace contents
workspace:
    ls -la /var/lib/openclaw/workspace/

# === Pairing ===

# List pending pairing requests
pairing:
    podman exec openclaw node /app/openclaw.mjs pairing list

# Approve a pairing request
pairing-approve channel code:
    podman exec openclaw node /app/openclaw.mjs pairing approve {{channel}} {{code}}

# === Browser ===

# Start browser
browser-start:
    podman exec openclaw node /app/openclaw.mjs browser start

# Stop browser
browser-stop:
    podman exec openclaw node /app/openclaw.mjs browser stop

# Show browser tabs
browser-tabs:
    podman exec openclaw node /app/openclaw.mjs browser tabs

# === Gateway ===

# Probe gateway
gateway-probe:
    podman exec openclaw node /app/openclaw.mjs gateway probe

# === Backup ===

# Create a backup of OpenClaw data
backup name="openclaw-backup":
    tar -czvf /tmp/{{name}}-$(date +%Y%m%d-%H%M%S).tar.gz -C /var/lib/openclaw .
    @echo "Backup created at /tmp/{{name}}-$(date +%Y%m%d-%H%M%S).tar.gz"

# === Maintenance ===

# Clear stale session locks
clear-locks:
    rm -f /var/lib/openclaw/agents/*/sessions/*.lock
    @echo "Session locks cleared"

# Pull latest container image
pull:
    podman pull ghcr.io/openclaw/openclaw:latest

# Update container (pull + restart)
update: pull restart
    @echo "OpenClaw updated"

# Run openclaw update (in-container update)
update-cli:
    podman exec openclaw node /app/openclaw.mjs update

# Fix fish autocomplete error
fish:
  true

# === TUI ===

# Open terminal UI
tui:
    podman exec -it openclaw node /app/openclaw.mjs tui

# === Agents ===

# List agents
agents:
    podman exec openclaw node /app/openclaw.mjs agents list
